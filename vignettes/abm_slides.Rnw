%% ==========================================================================
\section{Discussion}
%% ==========================================================================

\begin{frame}{The Epistemological Thread: Revisited}
  \begin{itemize}
    \item All five models today: same structure, same failure modes
    \item ODE assumes the structural conditions that make it reliable hold indefinitely
    \item ABM replaces this assumption with a distribution over futures
    \item The question is always: \textit{what are the conditions, and when do they break?}
  \end{itemize}
\end{frame}

\begin{frame}{Newton and the Conditions for Extrapolation}
  \begin{itemize}
    \item \citet{newton1687}: extrapolation works under conservation, closure, linearity
    \item Physics succeeds; ecology and epidemiology struggle with the same tools
    \item The conditions that make ODEs work are structural, not mathematical
    \item Checking those conditions is a \emph{statistical} task
  \end{itemize}
\end{frame}

\begin{frame}{The Hitting-Time Reframing}
  \begin{block}{Policy Question (ABM formulation)}
    What is the probability of crossing threshold $X$ before time $T$?
  \end{block}
  \begin{itemize}
    \item Conservation threshold, epidemic extinction, firm failure, etc.
    \item Requires distribution over futures $\Rightarrow$ stochastic ABM
    \item Answered by simulating many runs and computing empirical CDF
    \item The ODE gives one trajectory; the ABM gives a distribution
  \end{itemize}
\end{frame}

\begin{frame}{Strengths and Limitations of ABM}
  \begin{columns}
    \begin{column}{0.48\textwidth}
      \textbf{Strengths}
      \begin{itemize}
        \item Heterogeneity natural
        \item Stochasticity included
        \item Spatial structure explicit
        \item Hitting times computable
      \end{itemize}
    \end{column}
    \begin{column}{0.48\textwidth}
      \textbf{Limitations}
      \begin{itemize}
        \item Many free parameters
        \item Calibration is hard
        \item No analytical results
        \item Computationally expensive
      \end{itemize}
    \end{column}
  \end{columns}
\end{frame}

\begin{frame}{When to Use ABM vs.\ ODE vs.\ Statistical Models}
  \begin{center}
  \begin{tabular}{lp{5cm}}
    \toprule
    \textbf{Use} & \textbf{When} \\
    \midrule
    ODE      & Large $N$, short horizon, near equilibrium \\
    ABM      & Small $N$, long horizon, heterogeneity, hitting-time questions \\
    Stats    & Data-rich, prediction target well-defined, no mechanism needed \\
    All three & Triangulate: use agreement as model validation \\
    \bottomrule
  \end{tabular}
  \end{center}
\end{frame}

\begin{frame}{Further Reading}
  \begin{itemize}
    \item \citet{lotka1925}, \citet{volterra1926}: predator-prey foundations
    \item \citet{kermack1927}: SIR model
    \item \citet{karlin1975}: recurrence theorem
    \item \citet{anderssonbritton2000}: stochastic epidemic models
    \item \citet{diekmann1990}: next-generation matrix / spectral threshold
    \item \citet{barabasi1999}: preferential attachment networks
    \item \citet{axtell2001}: firm-size power law
    \item \citet{clauset2009}: power-law fitting methodology
  \end{itemize}
\end{frame}


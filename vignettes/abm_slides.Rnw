pp_model <- PredatorPreyModel$new(seed = 18L, width = 20L, height = 20L)
pp_out   <- pp_model$run(steps = 300L)

## ABM pandemic (grid)
pandemic_model <- PandemicModel$new(seed = 42L)
pandemic_out   <- pandemic_model$run(steps = 200L)

## Network pandemic
net_model <- NetworkPandemicModel$new(seed = 42L)
net_out   <- net_model$run(steps = 200L)

## Grass model
grass_model <- PredatorPreyGrassModel$new(seed = 10L, width = 20L, height = 20L)
grass_out   <- grass_model$run(steps = 300L)

